# Calendar
F1_ICS_URL=
USER_TIMEZONE=Asia/Kolkata
LOOKAHEAD_DAYS=90
OUTPUT_MODE=auto

# Notifications
EMAIL_ENABLED=true
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=
EMAIL_TO=
FORCE_NOTIFY=false
NOTIFICATION_WINDOW_HOURS=8

# Model and cache behavior
FORCE_RETRAIN=false
ML_START_YEAR=2018
USE_FULL_HISTORICAL_DATA=true
FULL_DATA_BACKFILL_LIMIT=10
JOLPICA_REQUEST_SLEEP=1.2

# Source toggles
UPGRADES_ENABLED=true
F1_REGULATIONS_ENABLED=true
OFFICIAL_CALENDAR_ENABLED=true
F1_LIVE_TIMING_STATIC_BASE=https://livetiming.formula1.com/static
OPENF1_ENABLED=true
OPENF1_BASE=https://api.openf1.org/v1
OPENF1_REQUEST_SLEEP=0.45
FIA_TECH_UPDATE_BASE=https://www.fia.com/news
OFFICIAL_F1_CALENDAR_URL=https://www.formula1.com/en/racing/{year}

# Local paths
MODEL_DIR=models/saved_models
HTTP_CACHE_DIR=data_cache/http
FULL_RACE_CACHE_DIR=data_cache/full_races
FASTF1_CACHE_DIR=fastf1_cache
